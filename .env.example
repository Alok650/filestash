# --- Security ---
# Admin API key required for administrative actions (creating/deactivating keys)
ADMIN_API_KEY=my-super-secret-admin-key

# Secret key for Django (use a long random string in production)
DJANGO_SECRET_KEY=django-insecure-default-key-for-development

# Set to False in production
DJANGO_DEBUG=True

# --- Limits ---
# Total storage allowed for all anonymous uploads combined (in MB)
ANONYMOUS_STORAGE_QUOTA_MB=100

# Maximum size of a single file upload (in MB)
MAX_UPLOAD_SIZE_MB=50
